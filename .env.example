# Blockchair API — DOGE, BTC, XRP 조회에 필요 (없으면 이 코인들은 state에 안 들어감)
# https://blockchair.com/api 에서 무료 키 발급
BLOCKCHAIR_API_KEY=

# Blockscout API (선택, PEPE 등 ERC-20용)
BLOCKSCOUT_API_KEY=

# Etherscan API (선택, tokenholderlist는 PRO 플랜)
# ETHERSCAN_API_KEY=

# Moralis API — SHIB 등 ERC-20 보유자 조회 (무료 tier 사용 가능)
# https://moralis.io 에서 키 발급
MORALIS_API_KEY=

# 알림: 콘솔만 사용 시 비워두면 됨. 텔레그램 봇 사용 시 입력
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DB: Supabase 사용 시 (로컬 수집 스크립트용)
# Supabase Dashboard > Project Settings > Database > Connection string (URI) 에서 복사 후 [YOUR-PASSWORD] 만 본인 DB 비밀번호로 치환
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# 로컬 PostgreSQL 사용 시 (기본값)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=admin
# POSTGRES_PASSWORD=admin
# POSTGRES_DB=mydb
